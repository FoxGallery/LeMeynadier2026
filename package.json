{
  "name": "lemeynadier2026",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Site vitrine de la brasserie Le Meynadier — Cannes.",
  "engines": {
    "node": ">=22.11.0"
  },
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "report:pdf": "node scripts/build-report.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,vue,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@nuxt/content": "^3.13.0",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/i18n": "^10.3.0",
    "@nuxtjs/seo": "^5.1.3",
    "@nuxtjs/sitemap": "^8.0.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "lucide-vue-next": "^1.0.0",
    "maplibre-gl": "^5.24.0",
    "nuxt": "^4.0.3",
    "reka-ui": "^2.9.7",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.13",
    "vue-router": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.4.14",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@iconify-json/lucide": "^1.2.105",
    "@iconify/vue": "^5.0.0",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.59.1",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.2.4",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.10",
    "better-sqlite3": "^12.9.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "satori": "^0.26.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "esbuild",
      "sharp",
      "vue-demi"
    ]
  }
}
